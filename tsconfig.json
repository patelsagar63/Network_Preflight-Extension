{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true,
    "rootDir": ".",
    "outDir": ".",
    "sourceMap": false
  },
  "include": ["tasks/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
