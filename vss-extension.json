{
  "manifestVersion": 1,
  "id": "AzureDevOpsCSS-Sagar",
  "publisher": "AzureDevOpsCSS-Sagar",
  "name": "Network Preflight",
  "version": "1.0.20",
  "description": "Azure Pipelines tasks to validate HTTP, DNS, and TCP connectivity from build/release agents before critical deployments.",
  "public": true,
  "categories": [ "Azure Pipelines" ],
  "targets": [
    { "id": "Microsoft.VisualStudio.Services" }
  ],
  "icons": {
    "default": "extension-icon.png"
  },
  "content": {
    "details": {
      "path": "overview.md"
    }
  },
  "files": [
    { "path": "tasks" },
    { "path": "README.md" }
  ],
  "contributions": [
    {
      "id": "network-preflight-httpcheck",
      "type": "ms.vss-distributed-task.task",
      "targets": [ "ms.vss-distributed-task.tasks" ],
      "properties": {
        "name": "tasks/HttpCheckV1"
      }
    },
    {
      "id": "network-preflight-dnslookup",
      "type": "ms.vss-distributed-task.task",
      "targets": [ "ms.vss-distributed-task.tasks" ],
      "properties": {
        "name": "tasks/DnsLookupV1"
      }
    },
    {
      "id": "network-preflight-tcpprobe",
      "type": "ms.vss-distributed-task.task",
      "targets": [ "ms.vss-distributed-task.tasks" ],
      "properties": {
        "name": "tasks/TcpProbeV1"
      }
    }
  ]
}